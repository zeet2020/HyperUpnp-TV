<resources>
    <!-- Base application theme: single dark "Midnight Archive" look, TV-first. -->
    <style name="Base.Theme.Hyperupnp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorSecondary">@color/accent_dim</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_bright</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@drawable/bg_window</item>
        <item name="android:textColorPrimary">@color/text_bright</item>
        <item name="android:textColorSecondary">@color/text_dim</item>
    </style>

    <style name="Theme.Hyperupnp" parent="Base.Theme.Hyperupnp" />

    <style name="TextAppearance.Hyperupnp.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/text_bright</item>
    </style>

    <style name="TextAppearance.Hyperupnp.NavItem" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="ShapeAppearanceOverlay.Hyperupnp.NavPill" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
